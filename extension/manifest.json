{
  "manifest_version": 3,
  "name": "timectx",
  "version": "1.0.0",
  "description": "Gives Claude the current date and time — automatically.",
  "permissions": [],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [{
    "matches": ["https://claude.ai/*"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "web_accessible_resources": [{
    "resources": ["inject.js"],
    "matches": ["https://claude.ai/*"]
  }],
  "action": {
    "default_popup": "popup.html"
  }
}
